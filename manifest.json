{
  "manifest_version": 3,
  "name": "RSS News New Tab",
  "version": "1.0",
  "description": "Clean and minimal RSS news feed on your new tab.",
  "author": "Remal Mahmud",
  "permissions": ["storage", "alarms", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "icons": {
    "128": "icon.png"
  }
}
