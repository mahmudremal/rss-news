{
  "manifest_version": 3,
  "name": "RSS News New Tab",
  "version": "1.0",
  "description": "Clean and minimal RSS news feed on your new tab.",
  "author": "Remal Mahmud",
  "permissions": ["storage", "alarms", "contextMenus"],
  "host_permissions": [
    "https://www.aljazeera.com/*",
    "https://images.unsplash.com/*",
    "https://source.unsplash.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon.png"
  }
}
